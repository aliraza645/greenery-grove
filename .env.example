# Set this to the running Express API. The frontend services in
# src/services/* call axios with this baseURL and attach the JWT from
# localStorage automatically.
VITE_API_URL=http://localhost:5000/api

# Cloudinary (unsigned upload preset) — used by the admin product image uploader.
# Create an unsigned upload preset in your Cloudinary dashboard and paste here.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
