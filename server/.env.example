# Server origin allowed to call the API. Comma-separated for multiple.
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080

PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/eplant
JWT_SECRET=change-me-in-prod
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Optional AI providers for /api/chat (both free tiers). If neither is set,
# the endpoint returns a friendly rule-based fallback so the widget still works.
# Groq — https://console.groq.com (free)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# OpenRouter — https://openrouter.ai (free models available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
